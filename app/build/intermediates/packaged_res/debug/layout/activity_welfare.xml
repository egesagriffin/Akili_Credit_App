<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/green_light"
    android:padding="24dp"
    android:gravity="center">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@android:drawable/ic_menu_help"
        app:tint="@color/green_mid"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welfare Check-In"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/green_dark"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_welfare_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="We noticed your activity has changed this month. We are here to support you, not just as a lender, but as a financial partner."
        android:textSize="16sp"
        android:textColor="@color/gray_700"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"
        android:lineSpacingExtra="4dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_restructure"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Restructure My Repayment"
        android:layout_marginBottom="12dp"
        app:cornerRadius="12dp"
        android:backgroundTint="@color/green_mid"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_pause"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Pause for 30 Days"
        android:layout_marginBottom="12dp"
        app:cornerRadius="12dp"
        app:strokeColor="@color/green_mid"
        android:textColor="@color/green_mid"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_wellness"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Connect with Financial Wellness"
        app:cornerRadius="12dp"
        android:textColor="@color/gray_500"/>

</LinearLayout>